<div class="darklight flex flex-col">
  <span class="text-_step2 w-fit">Dark Mode</span>
  <input type="checkbox" name="mode" id="mode" class="sr-only hidden" />

  <label
    class="switch bg-gray-800 dark:bg-gray-400 transition-colors duration-300"
    for="mode"
  >
    <div class="content-ball">
      <div class="ball"></div>
    </div>
  </label>
</div>

<style>
  .switch {
    width: 50px;
    height: 30px;
    z-index: 60;
    position: relative;
    border-radius: 50px;
    cursor: pointer;
    overflow: hidden;
  }

  .content-ball {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 4px;
    display: flex;
    align-items: center;
    z-index: 70;
    transition: left 0.5s ease;
    width: 100%;
  }

  .ball {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background-color: gray;
    border: none;
    outline: none;
    transition: background 0.5s ease;
    overflow: hidden;

    &::before {
      content: "";
      position: relative;
      width: 100%;
      height: 100%;
      left: 50%;
      /* float: left; */
      display: block;
      background-color: var(--color-black);
      transition:
        border-radius 0.5s ease,
        left 0.5s ease;
    }
  }

  #mode:checked + .switch .ball {
    background-color: whitesmoke;
  }

  #mode:checked + .switch .content-ball {
    left: calc(100% - 20px - 4px);

    .ball {
      &::before {
        border-radius: 50%;
        left: 32%;
      }
    }
  }

  .switch-active .content-ball {
    left: calc(100% - 20px - 4px);
  }

  .switch-active .ball::before {
    border-radius: 50%;
    left: 32%;
  }
</style>

<script>
  function syncSwitch() {
    const checkbox = document.getElementById("mode") as HTMLInputElement;
    if (!checkbox) return;

    const isDark = document.documentElement.classList.contains("dark");
    checkbox.checked = isDark;

    // Aplica clase inmediatamente sin esperar transición CSS
    const switchEl = checkbox.nextElementSibling as HTMLElement;
    switchEl?.classList.toggle("switch-active", isDark);

    checkbox.addEventListener("change", () => {
      const isDark = checkbox.checked;
      document.documentElement.classList.toggle("dark", isDark);
      localStorage.setItem("theme", isDark ? "dark" : "light");
      switchEl?.classList.toggle("switch-active", isDark);
    });
  }

  document.addEventListener("astro:page-load", syncSwitch);
</script>
